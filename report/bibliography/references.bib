@article{sun2020,
  title = {Flexural Buckling Behaviour of High-Chromium Stainless Steel Welded {{I-section}} Columns},
  author = {Sun, Yao and He, An and Liang, Yating and Zhao, Ou},
  date = {2020-09},
  journaltitle = {Thin-Walled Structures},
  shortjournal = {Thin-Walled Structures},
  volume = {154},
